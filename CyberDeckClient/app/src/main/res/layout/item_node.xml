<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nodeCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="#1A1A1A"
    app:cardCornerRadius="4dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Left: Status dot -->
        <View
            android:id="@+id/pulseDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/dot_amber"
            android:layout_marginEnd="12dp" />

        <!-- Center: Node info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/nodeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFA500"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/nodeIp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#80FFA500"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginTop="1dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/nodeMethod"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#4DFFA500"
                    android:textSize="9sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/nodeStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#4DFFA500"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Right: Connector chevron -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=">"
            android:textColor="#66FFA500"
            android:textSize="16sp"
            android:layout_marginStart="8dp"
            android:fontFamily="monospace" />
    </LinearLayout>

</androidx.cardview.widget.CardView>
